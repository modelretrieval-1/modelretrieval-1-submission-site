APP_NAME=NTCIR-19 ModelRetrieval Submissions Staging
APP_ENV=staging
DATABASE_PATH=/data/app.sqlite3
STORAGE_ROOT=/data/storage
SECRET_KEY=replace-with-a-unique-staging-secret
MAX_UPLOAD_BYTES=10485760

# Used by Docker Compose. CI/CD should replace this with a registry image.
APP_IMAGE=modelretrieval-submissions:staging
