# Temporary HTTP-only config for first certificate issuance.
# Replace submit.example.jp with the real production hostname.
# After Certbot creates certificates, replace this with production.conf.example.

server {
    listen 80;
    listen [::]:80;
    server_name submit.example.jp;

    client_max_body_size 12m;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        proxy_pass http://127.0.0.1:8002;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        proxy_redirect off;
    }
}
